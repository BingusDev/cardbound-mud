NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Used once when creating an admin character in the game client.
ADMIN_CODE=change-this-admin-code

# Legacy live-character token for admin API access.
ADMIN_TOKEN=change-this-admin-token

# Dedicated builder login. Recommended for the web admin panel.
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-this-builder-password
